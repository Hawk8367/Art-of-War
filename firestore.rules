rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Public leaderboard: readable by anyone signed in.
    match /leaderboard/{docId} {
      allow read: if isSignedIn();
      // Only server (Admin SDK) should write.
      allow write: if false;
    }

    // Lobbies + game state are server-authoritative.
    match /lobbies/{lobbyId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /lobbies/{lobbyId}/events/{eventId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /lobbies/{lobbyId}/submissions/{submissionId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

